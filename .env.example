# ═══════════════════════════════════════════════
#  X (Twitter) Auto Reply Bot — Configuration
#  Uses twitterapi.io + Ollama (LLaMA2)
# ═══════════════════════════════════════════════

# twitterapi.io API Key — get from https://twitterapi.io
TWITTER_API_KEY=

# Twitter/X Login Credentials
TWITTER_USERNAME=
TWITTER_EMAIL=
TWITTER_PASSWORD=
TWITTER_TOTP_SECRET=

# Proxy — REQUIRED by twitterapi.io (residential recommended)
# Format: http://username:password@ip:port
PROXY=

# Multiple proxies for rotation (comma-separated, optional)
# Bot auto-rotates on 226 blocks
PROXY_LIST=

# Ollama Config
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Bot Behavior
DRY_RUN=false
DASHBOARD_PORT=3000

# Auto-populated — bot logs in automatically on startup
LOGIN_COOKIE=
